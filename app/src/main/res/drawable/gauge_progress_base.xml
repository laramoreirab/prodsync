<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fundo do Arco (Sempre visível sob o progresso) -->
    <item>
        <rotate
            android:fromDegrees="180"
            android:toDegrees="180"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape
                android:innerRadiusRatio="2.5"
                android:shape="ring"
                android:thickness="10dp"
                android:useLevel="false">
                <solid android:color="#F0F0F0" />
            </shape>
        </rotate>
    </item>
    <!-- Progresso (Preenche sobre o fundo) -->
    <item>
        <rotate
            android:fromDegrees="180"
            android:toDegrees="180"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape
                android:innerRadiusRatio="2.5"
                android:shape="ring"
                android:thickness="10dp"
                android:useLevel="true">
                <solid android:color="#00357A" />
            </shape>
        </rotate>
    </item>
</layer-list>