<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true" >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Título Nome -->
        <TextView
            android:id="@+id/tv_nome_usuario_detalhe"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:text="Nome: José Adamastor Luís da Silva"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Foto de Perfil Circular -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_usuario_foto"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_account"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/cinza_claro"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/tv_nome_usuario_detalhe"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Lista de Informações -->
        <LinearLayout
            android:id="@+id/layout_info_lista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/iv_usuario_foto">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ID: " android:textStyle="bold" android:textSize="20sp" android:textColor="@color/black" android:fontFamily="@font/montserrat_bold"/>
                <TextView android:id="@+id/tv_id_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00000" android:textSize="20sp" android:fontFamily="@font/montserrat_medium" android:textColor="#444444"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="E-mail: " android:textStyle="bold" android:textSize="20sp" android:textColor="@color/black" android:fontFamily="@font/montserrat_bold"/>
                <TextView android:id="@+id/tv_email_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="josezinho@gmail.com" android:textSize="20sp" android:fontFamily="@font/montserrat_medium" android:textColor="#444444"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Setor: " android:textStyle="bold" android:textSize="20sp" android:textColor="@color/black" android:fontFamily="@font/montserrat_bold"/>
                <TextView android:id="@+id/tv_setor_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Engrenagens" android:textSize="20sp" android:fontFamily="@font/montserrat_medium" android:textColor="#444444"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Turno: " android:textStyle="bold" android:textSize="20sp" android:textColor="@color/black" android:fontFamily="@font/montserrat_bold"/>
                <TextView android:id="@+id/tv_turno_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Noite" android:textSize="20sp" android:fontFamily="@font/montserrat_medium" android:textColor="#444444"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Função: " android:textStyle="bold" android:textSize="20sp" android:textColor="@color/black" android:fontFamily="@font/montserrat_bold"/>
                <TextView android:id="@+id/tv_funcao_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Operador" android:textSize="20sp" android:fontFamily="@font/montserrat_medium" android:textColor="#444444"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CPF: " android:textStyle="bold" android:textSize="20sp" android:textColor="@color/black" android:fontFamily="@font/montserrat_bold"/>
                <TextView android:id="@+id/tv_cpf_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="443.651.730-65" android:textSize="20sp" android:fontFamily="@font/montserrat_medium" android:textColor="#444444"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Seção Responsável por -->
        <TextView
            android:id="@+id/tv_responsavel_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="Responsável por:"
            android:textSize="22sp"
            android:fontFamily="@font/montserrat_bold"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/layout_info_lista"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_maquina_responsavel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/tv_responsavel_label"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/iv_maquina_foto"
                    android:layout_width="160dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_ferramenta"
                    android:scaleType="centerInside" />

                <TextView
                    android:id="@+id/tv_maquina_nome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="THAK-909816"
                    android:textSize="20sp"
                    android:fontFamily="@font/montserrat_bold"
                    android:textColor="#212e4b" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>