<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true" >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Título Nome -->
        <TextView
            android:id="@+id/tv_nome_usuario_detalhe"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:text="Carregando..."
            android:textColor="@color/black"
            android:textSize="22sp"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Foto de Perfil Circular -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_usuario_foto"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_account"
            app:layout_constraintTop_toBottomOf="@id/tv_nome_usuario_detalhe"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Lista de Informações -->
        <LinearLayout
            android:id="@+id/layout_info_lista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/iv_usuario_foto">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:fontFamily="@font/montserrat_semibold" android:layout_height="wrap_content" android:text="ID: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_id_val" android:fontFamily="@font/montserrat_semibold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:fontFamily="@font/montserrat_semibold" android:layout_height="wrap_content" android:text="E-mail: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_email_val" android:fontFamily="@font/montserrat_semibold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:fontFamily="@font/montserrat_semibold" android:layout_height="wrap_content" android:text="Setor: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_setor_val" android:fontFamily="@font/montserrat_semibold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:fontFamily="@font/montserrat_semibold" android:layout_height="wrap_content" android:text="Turno: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_turno_val" android:fontFamily="@font/montserrat_semibold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textSize="18sp"/>
            </LinearLayout>


            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:fontFamily="@font/montserrat_semibold" android:layout_height="wrap_content" android:text="Função: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_funcao_val" android:fontFamily="@font/montserrat_semibold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:fontFamily="@font/montserrat_semibold" android:layout_height="wrap_content" android:text="CPF: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_cpf_val" android:fontFamily="@font/montserrat_semibold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textSize="18sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Seção Responsável por -->
        <TextView
            android:id="@+id/tv_responsavel_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="Responsável por:"
            android:textSize="22sp"
            android:fontFamily="@font/montserrat_bold"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/layout_info_lista"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_maquina_responsavel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/tv_responsavel_label"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/iv_maquina_foto"
                    android:layout_width="160dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_ferramenta"
                    android:scaleType="centerInside" />

                <TextView
                    android:id="@+id/tv_maquina_nome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="---"
                    android:textSize="20sp"
                    android:fontFamily="@font/montserrat_bold"
                    android:textColor="@color/machine_title" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Container de Loading -->
        <LinearLayout
            android:id="@+id/layout_loading_usuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/azul_marinho" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/montserrat_semibold"
                android:text="Sincronizando dados do usuário..."
                android:textColor="@color/azul_marinho"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Group para controle de visibilidade -->
        <androidx.constraintlayout.widget.Group
            android:id="@+id/group_conteudo_usuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="tv_nome_usuario_detalhe,iv_usuario_foto,layout_info_lista,tv_responsavel_label,card_maquina_responsavel" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>