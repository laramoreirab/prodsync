<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true" >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/iv_bg_pattern"
            android:layout_width="306dp"
            android:layout_height="350dp"
            android:src="@drawable/bg_s_logo"
            android:translationY="-75dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tv_nome_maquina_detalhe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="THAK-909816"
            android:textColor="#212e4b"
            android:textSize="28sp"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/underline"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_marginTop="2dp"
            android:background="@color/azul_marinho"
            app:layout_constraintEnd_toEndOf="@id/tv_nome_maquina_detalhe"
            app:layout_constraintStart_toStartOf="@id/tv_nome_maquina_detalhe"
            app:layout_constraintTop_toBottomOf="@id/tv_nome_maquina_detalhe" />

        <ImageView
            android:id="@+id/iv_maquina_grande"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginTop="24dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_ferramenta"
            app:layout_constraintTop_toBottomOf="@id/underline" />

        <LinearLayout
            android:id="@+id/layout_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/iv_maquina_grande">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ID: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_id_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00000" android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp" android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/tv_status_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Parada" android:paddingHorizontal="12dp" android:paddingVertical="2dp" android:background="@drawable/bg_badge_parada" android:textColor="@color/txt_parada" android:fontFamily="@font/montserrat_semibold" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Operador: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_operador_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Luis Adamastor" android:textSize="18sp"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/layout_info">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tv_oee_titulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OEE da Máquina"
                    android:fontFamily="@font/montserrat_bold"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:layout_marginBottom="24dp" />

                <LinearLayout
                    android:id="@+id/row_gauges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:weightSum="3">

                    <include android:id="@+id/gauge_disponibilidade" layout="@layout/view_oee_gauge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                    <include android:id="@+id/gauge_performance" layout="@layout/view_oee_gauge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                    <include android:id="@+id/gauge_qualidade" layout="@layout/view_oee_gauge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="32dp">

                    <FrameLayout
                        android:layout_width="200dp"
                        android:layout_height="110dp"
                        android:clipChildren="true">

                        <ProgressBar
                            android:id="@+id/pb_oee_consolidado"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:max="200"
                            android:progress="145"
                            android:rotation="180"
                            android:progressDrawable="@drawable/gauge_progress_consolidado" />

                        <TextView
                            android:id="@+id/tv_consolidado_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:text="72.5%"
                            android:textSize="32sp"
                            android:fontFamily="@font/montserrat_bold"
                            android:textColor="#212e4b"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OEE Geral Consolidado"
                        android:textSize="16sp"
                        android:fontFamily="@font/montserrat_bold"
                        android:layout_marginTop="8dp"
                        android:textColor="#212e4b"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>