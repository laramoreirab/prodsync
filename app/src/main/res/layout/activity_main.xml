<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/img_logo"
        android:layout_width="match_parent"
        android:layout_marginTop="10dp"
        android:layout_height="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/logo"/>

    <ImageView
        android:id="@+id/tv_produtividade"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="30dp"
        android:layout_marginHorizontal="10dp"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:tint="@color/azul_escuro"
        android:src="@drawable/txt_produtividade"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/img_logo"/>

    <TextView
        android:id="@+id/tv_sem_pausa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:text="sem pausa"
        android:textSize="50dp"
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_produtividade" />

    <TextView
        android:id="@+id/txt_descricao_home"
        android:layout_marginTop="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:gravity="center"
        android:text="Sua fábrica sincronizada em tempo real e sob controle"
        android:textSize="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_sem_pausa" />

    <LinearLayout
        android:id="@+id/btn_cadastrar"
        android:contentDescription="Botão de cadastro"
        android:roleDescription="button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_botao_pilula"
        android:backgroundTint="@color/azul_marinho"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="5dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_descricao_home">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:text="Cadastre-se"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/bg_circulo_branco"
            android:padding="7dp"
            android:src="@drawable/ic_seta"
            app:tint="@color/azul_marinho" />

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:layout_marginTop="56dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:contentPadding="24dp"
        app:layout_constraintTop_toBottomOf="@+id/btn_cadastrar"
        app:strokeColor="@color/cinza_claro"
        app:strokeWidth="1dp"
        tools:layout_editor_absoluteX="24dp">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
            android:id="@+id/tv_bem_vindo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bem-vindo de volta"
            app:layout_constraintTop_toTopOf="parent"
                android:fontFamily="@font/montserrat_semibold"
                android:textSize="20sp"
                android:textColor="@color/black"
            />

            <TextView
                android:id="@+id/tv_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Faça seu login"
                android:textSize="15sp"
                app:layout_constraintTop_toBottomOf="@+id/tv_bem_vindo"
                app:layout_constraintBottom_toTopOf="@+id/label_id"
                />

            <TextView
                android:id="@+id/label_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_medium"
                android:text="Identificador"
                android:textSize="13sp"
                android:textColor="@color/cinza_escuro"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@+id/tv_login" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/il_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/label_id"
                app:boxStrokeColor="@color/white"
                app:boxStrokeWidth="2px"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/label_senha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_medium"
                android:text="Senha"
                android:layout_marginTop="8dp"
                android:textSize="13sp"
                android:textColor="@color/cinza_escuro"
                app:layout_constraintTop_toBottomOf="@+id/il_id" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/il_senha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/label_senha"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_senha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_esqueceu_senha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Esqueceu a Senha?"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/il_senha" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_login"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/azul_escuro"
                android:text="Entrar"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_esqueceu_senha" />

            <TextView
                android:id="@+id/tv_cadastro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Não tem uma conta? Cadastre-se"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_login" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>


</androidx.constraintlayout.widget.ConstraintLayout>