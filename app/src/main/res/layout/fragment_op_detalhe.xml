<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">


        <TextView
            android:id="@+id/tv_titulo_op_detalhe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="OP #A554010"
            android:textColor="@color/machine_title"
            android:textSize="28sp"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/underline"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_marginTop="2dp"
            android:background="@color/azul_marinho"
            app:layout_constraintEnd_toEndOf="@id/tv_titulo_op_detalhe"
            app:layout_constraintStart_toStartOf="@id/tv_titulo_op_detalhe"
            app:layout_constraintTop_toBottomOf="@id/tv_titulo_op_detalhe" />

        <!-- Machine Meta Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_maquina_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="64dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/underline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_maquina_op"
                    android:layout_width="180dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_ferramenta"
                    android:scaleType="centerInside" />

                <TextView
                    android:id="@+id/tv_nome_maquina_op"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THAK-909816"
                    android:textColor="@color/machine_title"
                    android:textSize="22sp"
                    android:fontFamily="@font/montserrat_bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tv_meta_op"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meta: 300 peças"
                    android:textColor="@color/cinza"
                    android:textSize="16sp"
                    android:fontFamily="@font/montserrat_medium" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Details Info -->
        <LinearLayout
            android:id="@+id/layout_info_op"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/card_maquina_meta">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Setor: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_setor_op" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Roscas" android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp" android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/tv_status_op_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Produzindo" android:paddingHorizontal="12dp" android:paddingVertical="2dp" android:background="@drawable/bg_badge_produzindo" android:textColor="@color/txt_produzindo" android:fontFamily="@font/montserrat_semibold" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prioridade: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_prioridade_op_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Urgente" android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Operador: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_operador_op_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Luís Adamastor" android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data Início: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_data_inicio_op" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="13/09/2026 às 06:15" android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prazo Final: " android:textStyle="bold" android:textSize="18sp" android:textColor="@color/black"/>
                <TextView android:id="@+id/tv_prazo_final_op" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15/09/2026" android:textSize="18sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Progress Pie Chart Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_progresso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/layout_info_op">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progresso até término da OP"
                    android:fontFamily="@font/montserrat_bold"
                    android:textSize="14sp"
                    android:textColor="@color/black"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Atualizado em tempo real*"
                    android:textSize="10sp"
                    android:textColor="@color/cinza"/>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:layout_marginTop="16dp">

                    <ProgressBar
                        android:id="@+id/pb_pie_chart"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:max="100"
                        android:progress="83"
                        android:progressDrawable="@drawable/pie_chart_progress"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tv_label_a_produzir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A Produzir\n17,2%"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:gravity="center"
                        app:layout_constraintCircle="@+id/pb_pie_chart"
                        app:layout_constraintCircleAngle="315"
                        app:layout_constraintCircleRadius="135dp"
                        tools:ignore="MissingConstraints" />

                    <TextView
                        android:id="@+id/tv_label_produzidos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Produzido\n82,8%"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:gravity="center"
                        app:layout_constraintCircle="@+id/pb_pie_chart"
                        app:layout_constraintCircleAngle="135"
                        app:layout_constraintCircleRadius="135dp"
                        tools:ignore="MissingConstraints" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- OEE History Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_oee_resumo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/card_progresso">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resumo OEE geral da Máquina durante a OP"
                    android:fontFamily="@font/montserrat_bold"
                    android:textSize="12sp"
                    android:textColor="@color/black"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Atualizado em tempo real*"
                    android:textSize="8sp"
                    android:textColor="@color/cinza"/>

                <!-- Row of 3 Gauges -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:weightSum="3">

                    <include android:id="@+id/op_gauge_disponibilidade" layout="@layout/view_oee_gauge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                    <include android:id="@+id/op_gauge_performance" layout="@layout/view_oee_gauge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                    <include android:id="@+id/op_gauge_qualidade" layout="@layout/view_oee_gauge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                </LinearLayout>

                <!-- Consolidado OEE Gauge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="24dp">

                    <FrameLayout
                        android:layout_width="120dp"
                        android:layout_height="60dp"
                        android:clipChildren="true">

                        <ProgressBar
                            android:id="@+id/pb_op_oee_consolidado"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:max="200"
                            android:progress="72"
                            android:progressDrawable="@drawable/gauge_progress_consolidado" />

                        <TextView
                            android:id="@+id/tv_op_consolidado_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="4dp"
                            android:text="72.5%"
                            android:textSize="20sp"
                            android:fontFamily="@font/montserrat_bold"
                            android:textColor="@color/machine_title"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OEE Geral"
                        android:textSize="12sp"
                        android:fontFamily="@font/montserrat_bold"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/machine_title"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>