<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_voltar_op"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voltar para Ordens de Produção"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_titulo_op"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OP #A554010"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_voltar_op"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Placeholder para meta e gráficos de progresso -->
    <TextView
        android:id="@+id/tv_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Meta: 300 peças"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_titulo_op"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_status_op"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Produzindo"
        android:textColor="#4CAF50"
        app:layout_constraintTop_toBottomOf="@id/tv_meta"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>