# Configuracoes do Banco de Dados
# Conexao com pool
DATABASE_URL="postgresql://[user]:[password]@[endpoint]-pooler.[region].aws.neon.tech/[dbname]?sslmode=require"

# Conexao direta com Prisma CLI
DIRECT_URL="postgresql://[user]:[password]@[endpoint].[region].aws.neon.tech/[dbname]?sslmode=require"


# Configuracoes do Servidor
PORT=3001
NODE_ENV=development
CORS_ORIGINS="http://localhost:3000,https://prodsync-six.vercel.app"

# Configuracoes JWT
JWT_SECRET=320c2a4afff5ab80f94f1264f3e643a15d6d391affa6cde663a458c515f76e2d6e171700fa0c8916bdc1a0ee376627ac8b239faed6b5b7e533b1565ba789d60c
JWT_EXPIRES_IN=5h

# Configuracoes da IA
AZURE_OPENAI_ENDPOINT="https://recurso.openai.azure.com/"
AZURE_OPENAI_KEY=""
AZURE_OPENAI_DEPLOYMENT_NAME=""
AZURE_OPENAI_API_VERSION="2025-01-01"

# Configuracoes do Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER=""
CLOUDINARY_MACHINE_FOLDER="maquinas"

# Simulador de banco de dados
# Render Background Worker: npm run simulate
# Render Cron Job: npm run simulate:once
SIMULATOR_EMPRESA_IDS="43,44,45"
SIMULATOR_DASHBOARD_EMPRESA_IDS="43,44,45"
SIMULATOR_DASHBOARD_MIN_SETORES=5
SIMULATOR_INTERVAL_MS=60000
SIMULATOR_BATCH_SIZE=4
SIMULATOR_HISTORY_DAYS=7
SIMULATOR_PARALLEL_PARTS=3
SIMULATOR_TRIGGER_SECRET="um-segredo-grande"
# Cria apenas motivos/turnos se a empresa nao tiver nenhum cadastrado.
SIMULATOR_CREATE_SUPPORT_DATA=true
# Cria OPs quando uma maquina elegivel nao tiver ordem ativa.
SIMULATOR_CREATE_ORDERS=true
