generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum TipoUsuario {
  Adm
  Gestor
  Operador
}

enum StatusMaquina {
  Produzindo
  Parada
  Manutencao
  Setup
}

enum DiaSemana {
  Domingo
  Segunda
  Terca
  Quarta
  Quinta
  Sexta
  Sabado
}

enum TipoMotivoParada {
  Programada
  Nao_Programada @map("Nao Programada")
}

// --- MODELS ---

model Empresas {
  id_empresa        Int       @id @default(autoincrement())
  nome_empresa      String    @db.VarChar(255)
  cnpj              String    @unique @db.VarChar(18)
  data_cadastro     DateTime? @default(now())
  email             String?   @db.VarChar(255)
  telefone          String?   @db.VarChar(20)
  endereco          String?   @db.VarChar(255)
  nome_representante          String?   @db.VarChar(255)
  cpf_representante String?   @db.VarChar(14)

  // Relações
  usuarios           Usuarios[]
  setores            Setores[]
  categoria_maquinas Categoria_Maquina[]
  maquinas           Maquinas[]
  setor_gestores     Setor_Gestor[]
  turnos             Turno[]
  motivos_parada     Motivos_Parada[]
  ordens_producao    OrdemProducao[]
  historico_eventos  Historico_Eventos[]
  apontamentos       Apontamento[]
}

model Usuarios {
  id_usuario    Int         @id @default(autoincrement())
  id_empresa    Int
  nome          String      @db.VarChar(255)
  identificador String      @unique @db.VarChar(50)
  tipo          TipoUsuario
  cpf           String      @unique @db.VarChar(14)
  email         String?     @db.VarChar(255)

  empresa         Empresas         @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  setores_geridos Setor_Gestor[]
  escalas         EscalaTrabalho[]
  apontamentos    Apontamento[]
}

model Setores {
  id_setor   Int    @id @default(autoincrement())
  id_empresa Int
  nome_setor String @db.VarChar(100)

  empresa  Empresas       @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  maquinas Maquinas[]
  gestores Setor_Gestor[]
}

model Categoria_Maquina {
  id_categoria Int     @id @default(autoincrement())
  id_empresa   Int
  nome         String  @db.VarChar(100)
  descricao    String? @db.Text

  empresa  Empresas   @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  maquinas Maquinas[]
}

model Maquinas {
  id_maquina    Int           @id @default(autoincrement())
  id_empresa    Int
  nome          String        @db.VarChar(100)
  serie         String?       @unique @db.VarChar(50)
  status_atual  StatusMaquina @default(Parada)
  id_setor      Int
  id_categoria  Int
  data_ativacao DateTime?     @db.Date

  empresa           Empresas          @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  setor             Setores           @relation(fields: [id_setor], references: [id_setor])
  categoria         Categoria_Maquina @relation(fields: [id_categoria], references: [id_categoria])
  ordens_producao   OrdemProducao[]
  historico_eventos Historico_Eventos[]
  apontamentos      Apontamento[]
}

model Setor_Gestor {
  id_setor   Int
  id_gestor  Int
  id_empresa Int

  setor   Setores  @relation(fields: [id_setor], references: [id_setor], onDelete: Cascade)
  gestor  Usuarios @relation(fields: [id_gestor], references: [id_usuario], onDelete: Cascade)
  empresa Empresas @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)

  @@id([id_setor, id_gestor])
}

model Turno {
  id_turno    Int      @id @default(autoincrement())
  id_empresa  Int
  nome_turno  String   @db.VarChar(50)
  hora_inicio DateTime @db.Time
  hora_fim    DateTime @db.Time

  empresa           Empresas            @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  escalas           EscalaTrabalho[]
  historico_eventos Historico_Eventos[]
  apontamentos      Apontamento[]
}

model EscalaTrabalho {
  id_operador Int
  id_turno    Int
  dia_semana  DiaSemana

  operador Usuarios @relation(fields: [id_operador], references: [id_usuario], onDelete: Cascade)
  turno    Turno    @relation(fields: [id_turno], references: [id_turno], onDelete: Cascade)

  @@id([id_operador, id_turno, dia_semana])
}

model Motivos_Parada {
  id_motivo  Int              @id @default(autoincrement())
  id_empresa Int
  descricao  String           @db.VarChar(255)
  tipo       TipoMotivoParada @default(Nao_Programada)

  empresa           Empresas            @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  historico_eventos Historico_Eventos[]
}

model OrdemProducao {
  id_ordem       Int       @id @default(autoincrement())
  id_empresa     Int
  id_maquina     Int
  codigo_lote    String    @db.VarChar(100)
  produto        String    @db.VarChar(150)
  data_inicio    DateTime? 
  data_fim       DateTime? 
  qtd_planejada  Int

  empresa           Empresas            @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  maquina           Maquinas            @relation(fields: [id_maquina], references: [id_maquina])
  historico_eventos Historico_Eventos[]
  apontamentos      Apontamento[]
}

model Historico_Eventos {
  id_evento        Int           @id @default(autoincrement())
  id_empresa       Int
  id_maquina       Int
  id_ordemProducao Int?
  id_turno         Int
  id_motivo_parada Int?
  status_atual     StatusMaquina
  inicio           DateTime      
  termino          DateTime?     
  duracao          Int?          // Duração em minutos

  empresa        Empresas        @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  maquina        Maquinas        @relation(fields: [id_maquina], references: [id_maquina], onDelete: Cascade)
  ordem_producao OrdemProducao?  @relation(fields: [id_ordemProducao], references: [id_ordem])
  turno          Turno           @relation(fields: [id_turno], references: [id_turno])
  motivo_parada  Motivos_Parada? @relation(fields: [id_motivo_parada], references: [id_motivo])
}

model Apontamento {
  id_apontamento   Int      @id @default(autoincrement())
  id_empresa       Int
  id_ordemProducao Int
  id_maquina       Int
  id_operador      Int
  id_turno         Int
  qtd_boa          Int      @default(0)
  qtd_refugo       Int      @default(0)
  data_hora_inicio DateTime
  data_hora_fim    DateTime 
  observacao       String?  @db.Text

  empresa        Empresas      @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  ordem_producao OrdemProducao @relation(fields: [id_ordemProducao], references: [id_ordem], onDelete: Cascade)
  maquina        Maquinas      @relation(fields: [id_maquina], references: [id_maquina])
  operador       Usuarios      @relation(fields: [id_operador], references: [id_usuario])
  turno          Turno         @relation(fields: [id_turno], references: [id_turno])
}
