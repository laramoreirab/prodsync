<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/iv_maquina"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_ferramenta"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_nome_maquina"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="THAK-009"
            android:textColor="@color/machine_title"
            android:textSize="20sp"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_maquina"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_id_maquina"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Id: 1092"
            android:textColor="@color/machine_sub"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_medium"
            app:layout_constraintTop_toBottomOf="@id/tv_nome_maquina"
            app:layout_constraintStart_toStartOf="@id/tv_nome_maquina"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_serie_maquina"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Série: SX-900"
            android:textColor="@color/machine_sub"
            android:fontFamily="@font/montserrat_medium"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tv_id_maquina"
            app:layout_constraintStart_toStartOf="@id/tv_id_maquina"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parada"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/montserrat_semibold"
            android:background="@drawable/bg_badge_parada"
            android:textColor="@color/txt_parada"
            app:layout_constraintTop_toBottomOf="@id/tv_serie_maquina"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>